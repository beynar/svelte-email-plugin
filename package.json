{
	"name": "svelte-plugin-mail",
	"version": "0.3.1",
	"packageManager": "pnpm@10.32.1",
	"description": "A Svelte 5 port of react-email — build and render email-safe HTML emails with Svelte components.",
	"license": "MIT",
	"author": "beynar <arnaud@derbey.dev>",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/beynar/svelte-plugin-mail.git"
	},
	"homepage": "https://github.com/beynar/svelte-plugin-mail#readme",
	"bugs": "https://github.com/beynar/svelte-plugin-mail/issues",
	"publishConfig": {
		"access": "public"
	},
	"scripts": {
		"dev": "vite dev",
		"build": "vite build && npm run prepack",
		"preview": "vite preview",
		"prepare": "svelte-kit sync || echo ''",
		"prepack": "svelte-kit sync && svelte-package && publint",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"lint": "prettier --check . && eslint .",
		"format": "prettier --write .",
		"test:unit": "vitest",
		"test": "npm run test:unit -- --run"
	},
	"files": [
		"dist",
		"!dist/**/*.test.*",
		"!dist/**/*.spec.*"
	],
	"sideEffects": [
		"**/*.css"
	],
	"svelte": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"type": "module",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"svelte": "./dist/index.js"
		},
		"./render": {
			"types": "./dist/render.d.ts",
			"default": "./dist/render.js"
		},
		"./vite": {
			"types": "./dist/vite/index.d.ts",
			"default": "./dist/vite/index.js"
		}
	},
	"peerDependencies": {
		"postcss": "^8",
		"svelte": "^5.0.0",
		"tailwindcss": "^4"
	},
	"peerDependenciesMeta": {
		"postcss": {
			"optional": true
		},
		"tailwindcss": {
			"optional": true
		}
	},
	"devDependencies": {
		"@cloudflare/workers-types": "^4.20260616.1",
		"@eslint/js": "^10.0.1",
		"@sveltejs/adapter-auto": "^7.0.1",
		"@sveltejs/adapter-cloudflare": "^7.2.9",
		"@sveltejs/kit": "^2.63.0",
		"@sveltejs/package": "^2.5.8",
		"@sveltejs/vite-plugin-svelte": "^7.1.2",
		"@tailwindcss/vite": "^4.3.1",
		"@types/html-to-text": "^9.0.4",
		"@types/node": "^24",
		"@types/prismjs": "^1.26.6",
		"eslint": "^10.4.1",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-svelte": "^3.19.0",
		"globals": "^17.6.0",
		"postcss": "^8.5.15",
		"prettier": "^3.8.4",
		"prettier-plugin-svelte": "^4.1.0",
		"publint": "^0.3.21",
		"svelte": "^5.56.1",
		"svelte-check": "^4.6.0",
		"tailwindcss": "^4.3.1",
		"typescript": "^6.0.3",
		"typescript-eslint": "^8.60.1",
		"vite": "^8.0.16",
		"vitest": "^4.1.8"
	},
	"keywords": [
		"svelte",
		"email",
		"html-email",
		"react-email",
		"transactional-email",
		"svelte-email"
	],
	"dependencies": {
		"csstype": "^3.2.3",
		"html-to-text": "^10.0.0",
		"magic-string": "^0.30.21",
		"marked": "^18.0.5",
		"prismjs": "^1.30.0"
	}
}
